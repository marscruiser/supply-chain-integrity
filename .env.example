# ════════════════════════════════════════════════════════════════
#  SUPPLY CHAIN INTEGRITY SYSTEM — Environment Variables Template
#  Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ─── General ─────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here

# ─── Module A — Vision ───────────────────────────────────────────
VISION_HOST=0.0.0.0
VISION_PORT=8001
DATASET_PATH=./module_a_vision/datasets/raw
PROCESSED_PATH=./module_a_vision/datasets/processed
PHASH_THRESHOLD=10
SSIM_THRESHOLD=0.85
FINGERPRINT_ALGO=phash
ENABLE_GPU=false

# ─── Module B — Blockchain ───────────────────────────────────────
BLOCKCHAIN_NETWORK=development
# Ethereum / Hardhat
ETH_RPC_URL=http://127.0.0.1:8545
ETH_PRIVATE_KEY=your-private-key-here
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CHAIN_ID=1337
GAS_LIMIT=300000
# Hyperledger Fabric
FABRIC_CA_HOST=localhost
FABRIC_CA_PORT=7054
FABRIC_ORG=Org1MSP
FABRIC_CHANNEL=supply-chain-channel
FABRIC_CHAINCODE=supply_integrity

# ─── IPFS ────────────────────────────────────────────────────────
IPFS_HOST=127.0.0.1
IPFS_PORT=5001
IPFS_GATEWAY=http://127.0.0.1:8080
WEB3_STORAGE_TOKEN=your-web3-storage-token

# ─── Module C — API ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── MongoDB ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=supply_chain_integrity
MONGODB_USER=admin
MONGODB_PASSWORD=your-mongo-password

# ─── React Dashboard ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_NAME=SupplyGuard

# ─── Docker ──────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=supply_chain_integrity
